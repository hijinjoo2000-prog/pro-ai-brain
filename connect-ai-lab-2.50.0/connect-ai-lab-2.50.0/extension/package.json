{
  "name": "connect-ai-lab",
  "displayName": "Connect AI — AI 1인 기업 · 나만의 에이전트 팀 · 제2의 두뇌",
  "description": "AI 1인 기업가를 위한 워크스페이스. 나만의 AI 에이전트 팀과 제2의 두뇌가 한 곳에서 — CEO + 전문 에이전트들이 내 지식·결정 로그·메모리를 컨텍스트로 24시간 미션 향해 자동으로 일합니다. 100% 로컬·오프라인·무료.",
  "version": "2.50.0",
  "publisher": "connectailab",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wonseokjung/connect-ai"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Chat"
  ],
  "keywords": [
    "ai",
    "local",
    "ollama",
    "lmstudio",
    "gemma",
    "llama",
    "deepseek",
    "offline",
    "agent",
    "agent-team",
    "second-brain",
    "1인기업",
    "solopreneur",
    "code-generation",
    "connect-ai-lab",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "connect-ai-lab.newChat",
        "title": "Connect AI: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "connect-ai-lab.exportChat",
        "title": "Connect AI: Export Chat as Markdown"
      },
      {
        "command": "connect-ai-lab.explainSelection",
        "title": "Connect AI: Explain Selected Code"
      },
      {
        "command": "connect-ai-lab.focusChat",
        "title": "Connect AI: Focus Chat Input"
      },
      {
        "command": "connect-ai-lab.showBrainNetwork",
        "title": "Connect AI: Show Brain Topology 🧠"
      }
    ],
    "keybindings": [
      {
        "command": "connect-ai-lab.focusChat",
        "key": "cmd+l",
        "mac": "cmd+l"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "connect-ai-lab.explainSelection",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "connect-ai-lab-sidebar",
          "title": "Connect AI",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "connect-ai-lab-sidebar": [
        {
          "type": "webview",
          "id": "connect-ai-lab-v2-view",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Connect AI",
      "properties": {
        "connectAiLab.ollamaUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "🤖 AI 서버 주소 (보통 자동으로 잡히니 건드리지 않아도 됩니다)"
        },
        "connectAiLab.defaultModel": {
          "type": "string",
          "default": "",
          "description": "🧠 사용할 AI 모델 이름 (비워두면 설치된 모델 중 가장 작은 것이 자동 선택됨. 직접 지정 예: llama3.2:1b, gemma2:2b, qwen2.5:1.5b)"
        },
        "connectAiLab.requestTimeout": {
          "type": "number",
          "default": 300,
          "description": "⏱ AI 응답 대기 시간 (초, 기본 300초 = 5분)"
        },
        "connectAiLab.localBrainPath": {
          "type": "string",
          "default": "",
          "description": "📁 내 지식 폴더 경로 — 내 PC의 특정 폴더(예: 바탕화면/MyBrain)를 지정하면, 그 안의 .md 파일들이 AI의 지식이 됩니다. 비워두면 기본 폴더를 자동 생성합니다."
        },
        "connectAiLab.secondBrainRepo": {
          "type": "string",
          "default": "",
          "description": "🔗 깃허브 저장소 URL — 내 지식을 클라우드에 백업하고 동기화할 깃허브 저장소 주소입니다. (예: https://github.com/사용자/memory)"
        },
        "connectAiLab.companyDir": {
          "type": "string",
          "default": "",
          "description": "👔 1인 기업 폴더 경로 — 비워두면 ~/.connect-ai-brain/Company/에 자동 생성됩니다. 직접 지정하려면 절대 경로 또는 ~/로 시작하는 경로를 입력하세요."
        },
        "connectAiLab.assetsPath": {
          "type": "string",
          "default": "",
          "description": "🎨 (선택) LimeZu Modern Interiors 풀팩 폴더 — 사무실 뷰에 더 풍부한 캐릭터·인테리어를 쓰고 싶을 때만 지정합니다. 비워두면 vsix에 번들된 7개 캐릭터를 자동 사용합니다."
        },
        "connectAiLab.autoCycleEnabled": {
          "type": "boolean",
          "default": true,
          "description": "🤖 24시간 자율 사이클 — 켜두면 사용자가 30분 이상 자리를 비웠을 때 CEO가 회사 목표·각 에이전트 개인 목표를 검토해 자동으로 다음 한 스텝을 실행합니다. 에이전트 패널의 토글에서 같이 제어됩니다."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vercel/ncc": "^0.38.4",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "jsdom": "^29.0.2"
  }
}
